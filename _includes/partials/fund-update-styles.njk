  padding: 0;
  list-style: none;
  display: grid;
  gap: 0.75rem;
}
.fu-highlight-item {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--mv-text-primary);
  padding-left: 1rem;
  border-left: 2px solid rgba(255, 105, 180, 0.35);
}
