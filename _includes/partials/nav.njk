{# Shared site navigation. Highlights current page based on page.url. #}
{% set currentUrl = page.url or '' %}
{% set isHome = currentUrl == '/' %}
{% set isToken = currentUrl == '/messy-virgo-coin.html' %}
{% set isLitepaper = currentUrl == '/litepaper.html' %}
{% set isBuildlog = currentUrl == '/buildlog.html' %}
{% set isFundUpdateWeek = currentUrl.startsWith('/updates/') and currentUrl != '/updates/' %}
{% set isLiveFundUpdate = currentUrl == '/fund-update/' %}
{% set isBlog = currentUrl == '/blog/' or currentUrl.startsWith('/blog/') %}
{% set isUpdates = isBuildlog or isFundUpdateWeek or isLiveFundUpdate or isBlog %}
{% set latestUpdateUrl = collections.fundUpdates[0].url if collections.fundUpdates.length else '/fund-update/' %}
{% set isTrust = (currentUrl == '/founder-profiles.html') or (currentUrl == '/treasury.html') or (currentUrl == '/association.html') %}
{% set swapUrl = 'https://aerodrome.finance/swap?from=eth&to=0x09f87f948c88848363b124c9099cbb58e4cc7cb6&chain0=8453&chain1=8453' %}
{% set appUrl = 'https://app.messyvirgo.com/' %}

<nav id="navbar" class="glassmorphism shadow-lg">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex justify-between items-center h-16">
      <a href="/" class="text-2xl font-bold font-sans tracking-tight text-gradient">$MESSY</a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex space-x-5 items-center text-sm font-semibold">
        <a href="/" class="text-gray-300 hover:text-pink-400 transition{% if isHome %} text-pink-400{% endif %}">Home</a>

        <div class="relative group">
          <button type="button" class="text-gray-300 hover:text-pink-400 transition inline-flex items-center gap-1{% if isUpdates %} text-pink-400 hover:text-pink-300{% endif %}" aria-haspopup="true" aria-label="Updates menu">
            Updates
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="dropdown-menu absolute left-0 mt-2 pt-2 w-52 rounded-lg border border-white/10 bg-gray-900/95 backdrop-blur shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-opacity transition-visibility duration-200">
            <a href="{{ latestUpdateUrl }}" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition rounded-t-lg{% if isFundUpdateWeek or isLiveFundUpdate %} text-pink-400 font-semibold{% endif %}">Fund updates</a>
            <a href="/buildlog.html" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition{% if isBuildlog %} text-pink-400 font-semibold{% endif %}">Build Log</a>
            <a href="/blog/" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition rounded-b-lg{% if isBlog %} text-pink-400{% endif %}">Blog</a>
          </div>
        </div>

        <a href="/messy-virgo-coin.html" class="text-gray-300 hover:text-pink-400 transition{% if isToken %} text-pink-400{% endif %}">Token</a>

        <div class="relative group">
          <button type="button" class="text-gray-300 hover:text-pink-400 transition inline-flex items-center gap-1{% if isTrust %} text-pink-400 hover:text-pink-300{% endif %}" aria-haspopup="true" aria-label="Trust menu">
            Trust
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="dropdown-menu absolute right-0 mt-2 pt-2 w-56 rounded-lg border border-white/10 bg-gray-900/95 backdrop-blur shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-opacity transition-visibility duration-200">
            <a href="/treasury.html" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition rounded-t-lg{% if currentUrl == '/treasury.html' %} text-pink-400{% endif %}">Safes &amp; Vesting</a>
            <a href="/association.html" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition{% if currentUrl == '/association.html' %} text-pink-400{% endif %}">Association</a>
            <a href="/founder-profiles.html" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition{% if currentUrl == '/founder-profiles.html' %} text-pink-400{% endif %}">Founders</a>
            <a href="https://app.solidproof.io/projects/messyvirgo" target="_blank" rel="noopener noreferrer" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-pink-400 transition rounded-b-lg">SolidProof audit &amp; KYC</a>
          </div>
        </div>

        <a href="/litepaper.html" class="text-gray-300 hover:text-pink-400 transition{% if isLitepaper %} text-pink-400{% endif %}">Litepaper</a>
        <div class="flex items-center gap-2">
          <a href="{{ swapUrl }}" target="_blank" rel="noopener noreferrer" class="border border-pink-400/60 text-pink-400 px-4 py-2 rounded-md hover:bg-pink-400/10 hover:border-pink-400 transition text-sm font-semibold">Swap $MESSY</a>
          <a href="{{ appUrl }}" target="_blank" rel="noopener noreferrer" class="bg-pink-500 text-white px-4 py-2 rounded-md hover:bg-pink-600 transition shadow-lg shadow-pink-500/20 text-sm font-semibold">Open App</a>
        </div>
      </div>

      <!-- Mobile Nav Button -->
      <div class="lg:hidden">
        <button id="mobile-menu-button" class="text-gray-300 focus:outline-none" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-black/50 pb-4">
    <div class="flex gap-3 px-4 pt-3 pb-3">
      <a href="{{ appUrl }}" target="_blank" rel="noopener noreferrer" class="flex-1 py-3.5 text-sm text-center font-bold text-white bg-pink-500 hover:bg-pink-600 rounded-lg shadow-lg shadow-pink-500/20 transition">Open App</a>
      <a href="{{ swapUrl }}" target="_blank" rel="noopener noreferrer" class="flex-1 py-3.5 text-sm text-center font-bold text-pink-400 border border-pink-400/60 hover:bg-pink-400/10 rounded-lg transition">Swap $MESSY</a>
    </div>
    <div class="border-t border-white/10"></div>
    <a href="/" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Home</a>
    <div class="border-t border-white/10"></div>
    <div class="px-5 pt-4 pb-1 text-xs uppercase tracking-wider text-gray-500">Updates</div>
    <a href="{{ latestUpdateUrl }}" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Fund updates</a>
    <a href="/buildlog.html" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Build Log</a>
    <a href="/blog/" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Blog</a>
    <div class="border-t border-white/10"></div>
    <a href="/messy-virgo-coin.html" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Token</a>
    <div class="border-t border-white/10"></div>
    <div class="px-5 pt-4 pb-1 text-xs uppercase tracking-wider text-gray-500">Trust</div>
    <a href="/treasury.html" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Safes &amp; Vesting</a>
    <a href="/association.html" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Association</a>
    <a href="/founder-profiles.html" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Founders</a>
    <a href="https://app.solidproof.io/projects/messyvirgo" target="_blank" rel="noopener noreferrer" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">SolidProof</a>
    <div class="border-t border-white/10"></div>
    <a href="/litepaper.html" class="block py-3 px-5 text-sm text-gray-300 hover:bg-gray-800">Litepaper</a>
  </div>
</nav>
