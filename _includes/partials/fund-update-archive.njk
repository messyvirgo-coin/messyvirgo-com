{# Weekly fund update archive — included on every archived week and /fund-update/ #}
{% if collections.fundUpdates.length > 0 %}
<section class="fu-archive mt-10 pt-6 border-t border-white/10" aria-labelledby="fu-archive-heading">
  <h2 id="fu-archive-heading" class="mv-eyebrow mb-2">Archive</h2>
  <ul class="list-none m-0 p-0 space-y-1 text-sm">
    {% for week in collections.fundUpdates %}
    <li class="leading-snug">
      {% if fundUpdateSnapshot and week.url == page.url %}
      <span class="text-gray-300" aria-current="page">Week of {{ week.date | readableDate }}</span>
      {% else %}
      <a href="{{ week.url }}" class="text-gray-400 hover:text-pink-400 transition-colors no-underline">Week of {{ week.date | readableDate }}</a>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  {% if not fundUpdateSnapshot %}
  <p class="text-xs text-gray-500 mt-3 mb-0 leading-relaxed">Live data at build time; links above are frozen weekly snapshots.</p>
  {% endif %}
</section>
{% endif %}
