{% set fu = fu or fundUpdate %}
{% if not fu %}
<div class="mv-card glassmorphism rounded-lg p-6 mb-8">
  <p class="mv-body mb-0">Fund update data unavailable — rebuild after API is reachable.</p>
</div>
{% else %}

<div class="mv-card glassmorphism rounded-lg p-6 mb-8">
  <p class="mv-eyebrow mb-3">Fund / Signal update · {{ fu.snapshotDate }}</p>

  {% if showAutogenNotice %}
  <p class="mv-body text-sm text-gray-500 mb-4 pb-4 border-b border-white/10">Auto-generated at build time from <a href="https://api.messyvirgo.com" target="_blank" rel="noopener noreferrer">api.messyvirgo.com</a> — data reflects latest available.</p>
  {% endif %}

  <p class="mv-body mb-0 border-l-2 border-pink-400/40 pl-4 text-gray-300">Each week: what changed across our Guru funds on Base — Guru Lotus read-only NAV snapshots (messybased, messyinfra) plus micro test funds on Guru (base01–03) that run the full screening → council → target-change workflow. Those micro funds are traded by the fund workflow; target changes execute manually or automatically only after council resolution. We pair that with macro, narratives, and screening context: what moved, what was passed on, and what the process teaches about AI-managed Funds. Published for transparency only; this update does not execute trades or rotate the books.</p>
</div>

<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>

<p class="mv-eyebrow mb-4">Guru Lotus (read-only NAV)</p>

<div class="fu-fund-grid">
{% for fund in fu.funds %}
  {% if fund.group == "guru" %}
  <a class="fu-fund-card mv-card glassmorphism rounded-lg p-6 block text-gray-200 no-underline hover:shadow-lg hover:shadow-pink-500/20" href="{{ fund.appUrl }}" target="_blank" rel="noopener noreferrer">
    <div class="fc-name">{{ fund.name }}</div>
    <div class="fc-nav">{{ fund.nav }} NAV</div>
    <div class="fc-returns">
      <span class="fc-ret {{ fund.ret1d.cls }}">{{ fund.ret1d.value }} 1d</span>
      <span class="fc-ret {{ fund.ret7d.cls }}">{{ fund.ret7d.value }} 7d</span>
      <span class="fc-ret {{ fund.ret30d.cls }}">{{ fund.ret30d.value }} 30d</span>
    </div>
    <div class="fc-desc">{{ fund.positionCount }} position{% if fund.positionCount != 1 %}s{% endif %}{% if fund.screening.aggDate %} · agg {{ fund.screening.aggDate }}{% endif %}</div>
  </a>
  {% endif %}
{% endfor %}
</div>

<p class="mv-eyebrow mb-4 mt-8">Micro test funds on Guru (workflow-traded)</p>

<div class="fu-fund-grid fu-fund-grid--micro">
{% for fund in fu.funds %}
  {% if fund.group == "guru-micro" or fund.group == "micro" %}
  <a class="fu-fund-card mv-card glassmorphism rounded-lg p-6 block text-gray-200 no-underline hover:shadow-lg hover:shadow-pink-500/20" href="{{ fund.appUrl }}" target="_blank" rel="noopener noreferrer">
    <div class="fc-name">{{ fund.name }}</div>
    <div class="fc-nav">{{ fund.nav }} NAV</div>
    <div class="fc-returns">
      <span class="fc-ret {{ fund.ret1d.cls }}">{{ fund.ret1d.value }} 1d</span>
      <span class="fc-ret {{ fund.ret7d.cls }}">{{ fund.ret7d.value }} 7d</span>
      <span class="fc-ret {{ fund.ret30d.cls }}">{{ fund.ret30d.value }} 30d</span>
    </div>
    <div class="fc-desc">{{ fund.positionCount }} position{% if fund.positionCount != 1 %}s{% endif %}{% if fund.screening.aggDate %} · agg {{ fund.screening.aggDate }}{% endif %}{% if fund.council %} · council {{ fund.council.outcomeLabel }}{% endif %}</div>
  </a>
  {% endif %}
{% endfor %}
</div>

<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>

{% for fund in fu.funds %}
<p class="mv-eyebrow mb-4">{{ fund.name }} — screening &amp; council</p>

{% if fund.holdingsBar.length %}
<div class="fu-holdings">
  <div class="fu-holdings-label">Current book</div>
  <div class="fu-bar">
    {% for seg in fund.holdingsBar %}
    <div class="fu-bar-seg" style="width:{{ seg.weight }}%;background:{{ seg.color }};opacity:0.85" title="{{ seg.symbol }} {{ seg.weight }}%"></div>
    {% endfor %}
  </div>
  <div class="fu-bar-legend">
    {% for seg in fund.holdingsBar %}
    <span class="fu-leg">
      <span class="fu-leg-dot" style="background:{{ seg.color }}"></span>
      {{ seg.symbol }} {{ seg.weight }}%{% if seg.warning %} ⚠️{% endif %}
    </span>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if fund.basePositions.length %}
<p style="font-size:.85rem;color:#d1d5db;margin-bottom:1rem;">
  {% for p in fund.basePositions %}
    <strong>{{ p.symbol }}</strong> {{ p.value }}{% if p.pnl %} ({{ p.pnl }} PnL){% endif %}{% if not loop.last %}, {% endif %}
  {% endfor %}
</p>
{% endif %}

{% if fund.screening.aggCandidates.length %}
<p style="font-size:.8rem;color:#6b7280;margin-bottom:.5rem;">
  <strong style="color:#9ca3af;">{{ fund.screening.aggLookback }}-day aggregate</strong> — {{ fund.screening.aggSourceRuns }} source runs, as of {{ fund.screening.aggDate or "–" }}
</p>
<div class="fu-candidates">
  {% for c in fund.screening.aggCandidates %}
  <div class="fu-cand-row">
    <span class="fu-cand-rank">#{{ c.rank }}</span>
    <span class="fu-cand-sym">{{ c.symbol }}</span>
    <span class="fu-cand-reason">{{ c.reason }}</span>
  </div>
  {% endfor %}
</div>
{% endif %}

{% if fund.council %}
<div class="fu-council{% if fund.council.targetFinalizationBlocked %} fu-council--blocked{% elif fund.council.certified == false %} fu-council--pending{% endif %}">
  <div class="fu-council-icon">{% if fund.council.outcome == "maintain_current" %}🔒{% elif fund.council.outcome == "target_change" %}🔄{% elif fund.council.targetFinalizationBlocked %}⚠️{% else %}⚖️{% endif %}</div>
  <div class="fu-council-body">
    <div class="fu-council-outcome">
      Council{% if fund.council.certificationLabel %} · {{ fund.council.certificationLabel }}{% elif fund.council.certified %} · certified{% endif %} · {{ fund.council.outcomeLabel }}{% if fund.council.date %} · {{ fund.council.date }}{% endif %}
    </div>
    {% if fund.council.targetFinalization %}
    <p class="fu-council-detail"><strong>Target finalization:</strong> {{ fund.council.targetFinalization }}</p>
    {% endif %}
    <p>{{ fund.council.riskNotes or fund.council.headline or "See app for full council protocol." }}</p>
    {% if fund.council.actionItems %}
    <p class="fu-council-detail"><strong>Action items:</strong> {{ fund.council.actionItems }}</p>
    {% endif %}
  </div>
</div>
{% endif %}

{% if not loop.last %}<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>{% endif %}
{% endfor %}

<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>

<p class="mv-eyebrow mb-4">Market regime — macro economics</p>

{% if fu.macro %}
<div class="fu-macro mv-card glassmorphism rounded-lg p-6 mb-6">
  <div class="fu-macro-score">
    <div class="ms-val">{{ fu.macro.score }}</div>
    <div class="ms-label">{{ fu.macro.regime }}</div>
  </div>
  <div class="fu-macro-summary">{{ fu.macro.summary }}</div>
</div>
{% endif %}

<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>

<p class="mv-eyebrow mb-4">Narrative momentum — {{ fu.snapshotDate }}</p>

{% if fu.narratives.length %}
<div class="fu-narr-wrap">
<table class="fu-narr-table" style="margin:0">
  <thead>
    <tr>
      <th>Narrative</th>
      <th>15d</th>
      <th>30d</th>
      <th>60d</th>
      <th title="Percentage points above or below BTC over 15 days">vs BTC 15d</th>
      <th>Read</th>
    </tr>
  </thead>
  <tbody>
    {% for n in fu.narratives %}
    <tr>
      <td>{{ n.label }}</td>
      <td class="{{ 'narr-chg-pos' if n.chg15Pos else 'narr-chg-neg' }}">{{ n.chg15 }}</td>
      <td class="{{ 'narr-chg-pos' if n.chg30Pos else 'narr-chg-neg' }}">{{ n.chg30 }}</td>
      <td class="{{ 'narr-chg-pos' if n.chg60Pos else 'narr-chg-neg' }}">{{ n.chg60 }}</td>
      <td class="{{ 'narr-chg-pos' if n.vsBtc15Pos else 'narr-chg-neg' }}">{{ n.vsBtc15 }}</td>
      <td><span class="narr-pill {{ n.pill }}">{{ n.pillLabel }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% if fu.macro and fu.macro.aiAgentsNote %}
<p style="font-size:.85rem;color:#9ca3af;line-height:1.65;margin-top:1rem;">
  <strong style="color:#e5e7eb;">{{ fu.macro.aiAgentsNote.label }}</strong> is {{ fu.macro.aiAgentsNote.chg15 }} over 15d but {{ fu.macro.aiAgentsNote.vsBtc15 }} vs BTC — absolute strength does not always mean allocation-worthy beta.
</p>
{% endif %}
{% endif %}

{% if fu.signalExample or fu.riskReject %}
<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>
<p class="mv-eyebrow mb-4">Aggregate signal · Risk reject</p>
<div class="fu-signal-grid">
  {% if fu.signalExample %}
  <div class="fu-signal-card candidate">
    <div class="fu-signal-eyebrow">✅ Aggregate signal</div>
    <div class="fu-signal-token">{{ fu.signalExample.symbol }}</div>
    <div class="fu-signal-name">{{ fu.signalExample.name }}</div>
    <div class="fu-signal-body">{{ fu.signalExample.body | safe }}</div>
    <div class="fu-signal-meta">
      {% for tag in fu.signalExample.tags %}
      <span class="fu-signal-tag">{{ tag }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% if fu.riskReject %}
  <div class="fu-signal-card reject">
    <div class="fu-signal-eyebrow">❌ Risk reject</div>
    <div class="fu-signal-token">{{ fu.riskReject.symbol }}</div>
    <div class="fu-signal-name">{{ fu.riskReject.name }} · {{ fu.riskReject.fundName }}</div>
    <div class="fu-signal-body">{{ fu.riskReject.body }}</div>
    <div class="fu-signal-meta">
      {% for tag in fu.riskReject.tags %}
      <span class="fu-signal-tag">{{ tag }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>
{% endif %}

<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>

<div class="fu-agent-box mv-card glassmorphism rounded-lg p-6 mb-8">
  <h3 class="mv-eyebrow mb-4">What this teaches the future Fund Agent</h3>
  <div class="fu-agent-patterns">
    <div class="fu-pattern">
      <div class="fu-pattern-num">1</div>
      <div class="fu-pattern-text"><strong>Macro gates gross exposure.</strong> {% if fu.macro %}Neutral regime ({{ fu.macro.score }} {{ fu.macro.regime }}){% else %}Regime context{% endif %} → defensive funds stay in core; beta funds rotate within the book, not expand it blindly.</div>
    </div>
    <div class="fu-pattern">
      <div class="fu-pattern-num">2</div>
      <div class="fu-pattern-text"><strong>Daily screen ≠ automatic trade.</strong> The day's #1 candidate and the {{ fu.funds[0].screening.aggLookback or 7 }}-day aggregate leader can differ — the agent needs both horizons, not just the latest signal.</div>
    </div>
    <div class="fu-pattern">
      <div class="fu-pattern-num">3</div>
      <div class="fu-pattern-text"><strong>Council is the constraint layer.</strong> Certified outcomes encode PM conflict, guardrail breaches, and explicit rotate-out lists. This is training data for autonomous Funds — not marketing copy.</div>
    </div>
  </div>
</div>

<div class="mv-treasury-sep"><div class="mv-treasury-sep-inner"></div></div>

<p class="mv-eyebrow mb-4">Run the same workflow</p>

<div class="fu-links-grid">
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="https://app.messyvirgo.com/funds" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">🏦</span> All Funds</a>
  {% for fund in fu.funds %}
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="{{ fund.appUrl }}" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">📊</span> {{ fund.name }}</a>
  {% endfor %}
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="https://app.messyvirgo.com/macro-economics" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">🌐</span> Macro Economics</a>
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="https://app.messyvirgo.com/narratives" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">📈</span> Narrative Momentum</a>
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="https://app.messyvirgo.com/due-diligence/performance" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">⚡</span> Performance Signals</a>
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="https://app.messyvirgo.com/due-diligence/social" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">💬</span> Social Signals</a>
  <a class="fu-link-pill mv-card glassmorphism rounded-lg p-4" href="https://app.messyvirgo.com/due-diligence/security" target="_blank" rel="noopener noreferrer"><span class="fu-link-icon" aria-hidden="true">🔒</span> Security Signals</a>
</div>

{% if showAutogenNotice %}<p style="margin-top:2rem;font-size:.82rem;color:#6b7280;text-align:center">Data auto-fetched at build time</p>{% endif %}

{% endif %}
