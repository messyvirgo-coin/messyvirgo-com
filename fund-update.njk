    <div class="fc-name">{{ fund.name }}</div>
    <div class="fc-nav">{{ fund.nav }} NAV</div>
    <div class="fc-returns">
      <span class="fc-ret {{ fund.ret1d.cls }}">{{ fund.ret1d.value }} 1d</span>
      <span class="fc-ret {{ fund.ret7d.cls }}">{{ fund.ret7d.value }} 7d</span>
      <span class="fc-ret {{ fund.ret30d.cls }}">{{ fund.ret30d.value }} 30d</span>
    </div>
    <div class="fc-desc">{{ fund.positionCount }} position{% if fund.positionCount != 1 %}s{% endif %} · {{ fund.screening.runDate or "–" }}</div>
  </a>
{% endfor %}
</div>

<hr class="fu-divider">

{% for fund in fundUpdate.funds %}
<div class="fu-section-label">{{ fund.name }} — screening &amp; council</div>

{% if fund.holdingsBar.length %}
<div class="fu-holdings">
  <div class="fu-holdings-label">Current book</div>
  <div class="fu-bar">
    {% for seg in fund.holdingsBar %}
    <div class="fu-bar-seg" style="width:{{ seg.weight }}%;background:{{ seg.color }};opacity:0.85" title="{{ seg.symbol }} {{ seg.weight }}%"></div>
    {% endfor %}
  </div>
  <div class="fu-bar-legend">
    {% for seg in fund.holdingsBar %}
    <span class="fu-leg">
      <span class="fu-leg-dot" style="background:{{ seg.color }}"></span>
      {{ seg.symbol }} {{ seg.weight }}%{% if seg.warning %} ⚠️{% endif %}
    </span>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if fund.basePositions.length %}
<p style="font-size:.85rem;color:#d1d5db;margin-bottom:1rem;">
  {% for p in fund.basePositions %}
    <strong>{{ p.symbol }}</strong> {{ p.value }}{% if p.pnl %} ({{ p.pnl }} PnL){% endif %}{% if not loop.last %}, {% endif %}
  {% endfor %}
</p>
{% endif %}

{% if fund.screening.aggCandidates.length %}
<p style="font-size:.8rem;color:#6b7280;margin-bottom:.5rem;">
  <strong style="color:#9ca3af;">{{ fund.screening.aggLookback }}-day aggregate</strong> — {{ fund.screening.aggSourceRuns }} source runs, as of {{ fund.screening.aggDate or "–" }}
</p>
<div class="fu-candidates">
  {% for c in fund.screening.aggCandidates %}
  <div class="fu-cand-row">
    <span class="fu-cand-rank">#{{ c.rank }}</span>
    <span class="fu-cand-sym">{{ c.symbol }}</span>
    <span class="fu-cand-reason">{{ c.reason }}</span>
  </div>
  {% endfor %}
</div>
{% endif %}

{% if fund.council %}
<div class="fu-council">
  <div class="fu-council-icon">{% if fund.council.outcome == "maintain_current" %}🔒{% elif fund.council.outcome == "target_change" %}🔄{% else %}⚖️{% endif %}</div>
  <div class="fu-council-body">
    <div class="fu-council-outcome">
      Council certified · {{ fund.council.outcomeLabel }}{% if fund.council.date %} · {{ fund.council.date }}{% endif %}
    </div>
    <p>{{ fund.council.riskNotes or "See app for full council protocol." }}</p>
  </div>
</div>
{% endif %}

{% if not loop.last %}<hr class="fu-divider">{% endif %}
{% endfor %}

<hr class="fu-divider">

<div class="fu-section-label">Market regime — macro economics</div>

{% if fundUpdate.macro %}
<div class="fu-macro">
  <div class="fu-macro-score">
    <div class="ms-val">{{ fundUpdate.macro.score }}</div>
    <div class="ms-label">{{ fundUpdate.macro.regime }}</div>
  </div>
  <div class="fu-macro-summary">{{ fundUpdate.macro.summary }}</div>
</div>
{% endif %}

<hr class="fu-divider">

<div class="fu-section-label">Narrative momentum — {{ fundUpdate.snapshotDate }}</div>

{% if fundUpdate.narratives.length %}
<table class="fu-narr-table">
  <thead>
    <tr>
      <th>Narrative</th>
      <th>15d</th>
      <th>30d</th>
      <th>60d</th>
      <th title="Percentage points above or below BTC over 15 days">vs BTC 15d</th>
      <th>Read</th>
    </tr>
  </thead>
  <tbody>
    {% for n in fundUpdate.narratives %}
    <tr>
      <td>{{ n.label }}</td>
      <td class="{{ 'narr-chg-pos' if n.chg15Pos else 'narr-chg-neg' }}">{{ n.chg15 }}</td>
      <td class="{{ 'narr-chg-pos' if n.chg30Pos else 'narr-chg-neg' }}">{{ n.chg30 }}</td>
      <td class="{{ 'narr-chg-pos' if n.chg60Pos else 'narr-chg-neg' }}">{{ n.chg60 }}</td>
      <td class="{{ 'narr-chg-pos' if n.vsBtc15Pos else 'narr-chg-neg' }}">{{ n.vsBtc15 }}</td>
      <td><span class="narr-pill {{ n.pill }}">{{ n.pillLabel }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<hr class="fu-divider">

<div class="fu-agent-box">
  <h3>What this teaches the future Fund Agent</h3>
  <div class="fu-agent-patterns">
    <div class="fu-pattern">
