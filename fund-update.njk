.fu-cand-rank { width:1.25rem; color:#6b7280; font-size:.75rem; flex-shrink:0; }
.fu-cand-sym { font-weight:700; color:#e5e7eb; min-width:3.5rem; }
.fu-cand-reason { color:#9ca3af; font-size:.78rem; }

