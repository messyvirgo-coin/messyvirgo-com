.fu-macro-summary { flex:1; min-width:200px; font-size:.85rem; color:#d1d5db; line-height:1.65; }

/* Narrative table */
.fu-narr-table { width:100%; border-collapse:collapse; font-size:.83rem; margin-bottom:1.5rem; }
.fu-narr-table th { text-align:left; font-size:.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6b7280; padding:.5rem .75rem; border-bottom:1px solid rgba(255,255,255,.07); }
.fu-narr-table td { padding:.65rem .75rem; border-bottom:1px solid rgba(255,255,255,.04); color:#d1d5db; vertical-align:middle; }
.fu-narr-table tr:last-child td { border-bottom:none; }
.fu-narr-table td:first-child { font-weight:600; color:#e5e7eb; }
.narr-chg-pos { color:#4ade80; font-weight:700; }
.narr-chg-neg { color:#f87171; font-weight:700; }
.narr-pill { display:inline-block; font-size:.68rem; font-weight:600; padding:.15rem .5rem; border-radius:9999px; }
.narr-pill.hot  { background:rgba(255,105,180,.12); color:#ff69b4; }
.narr-pill.watch{ background:rgba(251,191,36,.1);  color:#fbbf24; }
.narr-pill.fade { background:rgba(248,113,113,.1); color:#f87171; }

/* Agent learning box */
.fu-agent-box { background:linear-gradient(135deg,rgba(255,105,180,.05),rgba(255,215,0,.03)); border:1px solid rgba(255,105,180,.2); border-radius:12px; padding:1.5rem; margin-bottom:2rem; }
.fu-agent-box h3 { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#ff69b4; margin:0 0 1rem; }
.fu-agent-patterns { display:flex; flex-direction:column; gap:.75rem; }
.fu-pattern { display:flex; gap:.75rem; align-items:flex-start; }
.fu-pattern-num { flex-shrink:0; width:22px; height:22px; border-radius:50%; background:rgba(255,105,180,.15); color:#ff69b4; font-size:.7rem; font-weight:700; display:flex; align-items:center; justify-content:center; margin-top:.1rem; }
.fu-pattern-text { font-size:.85rem; color:#d1d5db; line-height:1.6; }
.fu-pattern-text strong { color:#e5e7eb; }

/* Links grid */
.fu-links-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:.65rem; margin-top:1rem; }
.fu-link-pill { display:flex; align-items:center; gap:.5rem; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.08); border-radius:8px; padding:.6rem .85rem; font-size:.78rem; font-weight:500; color:#9ca3af; text-decoration:none; transition:border-color .2s,color .2s; }
.fu-link-pill:hover { border-color:rgba(255,105,180,.35); color:#ff69b4; text-decoration:none; }
.fu-link-icon { font-size:.85rem; }

