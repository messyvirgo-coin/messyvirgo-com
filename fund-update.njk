/* Candidates list */
.fu-candidates { margin:.75rem 0 1.25rem; }
.fu-cand-row { display:flex; gap:.5rem; align-items:baseline; padding:.35rem 0; border-bottom:1px solid rgba(255,255,255,.04); font-size:.83rem; }
