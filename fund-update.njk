<style>
/* ── Fund Update dynamic page styles ── */
.fu-lead { font-size:1.1rem; color:#9ca3af; line-height:1.75; margin-bottom:2.5rem; border-left:3px solid rgba(255,105,180,0.4); padding-left:1.25rem; }
.fu-badge { display:inline-flex; align-items:center; gap:.35rem; background:rgba(255,105,180,.08); border:1px solid rgba(255,105,180,.22); border-radius:9999px; padding:.3rem .85rem; font-size:.75rem; color:#ff69b4; font-weight:600; letter-spacing:.04em; text-transform:uppercase; margin-bottom:2rem; }
.fu-section-label { font-size:.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#ff69b4; margin-bottom:1rem; display:flex; align-items:center; gap:.5rem; }
.fu-section-label::after { content:''; flex:1; height:1px; background:rgba(255,105,180,.15); }
.fu-divider { border:none; border-top:1px solid rgba(255,255,255,.06); margin:3rem 0; }

/* Fund cards */
.fu-fund-grid { display:grid; grid-template-columns:1fr; gap:1rem; margin-bottom:2.5rem; }
@media(min-width:640px){ .fu-fund-grid{ grid-template-columns:repeat(3,1fr); } }
.fu-fund-card { background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.08); border-radius:12px; padding:1.25rem; transition:border-color .2s,background .2s; text-decoration:none; display:block; }
.fu-fund-card:hover { border-color:rgba(255,105,180,.3); background:rgba(255,105,180,.04); }
.fc-name { font-size:.85rem; font-weight:700; color:#e5e7eb; margin-bottom:.25rem; }
.fc-nav  { font-size:1.3rem; font-weight:700; color:#fff; margin-bottom:.75rem; }
.fc-returns { display:flex; gap:.6rem; flex-wrap:wrap; margin-bottom:.85rem; }
.fc-ret { font-size:.75rem; font-weight:600; padding:.15rem .55rem; border-radius:9999px; }
.fc-ret.pos { background:rgba(74,222,128,.12); color:#4ade80; }
.fc-ret.neg { background:rgba(248,113,113,.12); color:#f87171; }
.fc-ret.neu { background:rgba(156,163,175,.12); color:#9ca3af; }
.fc-desc { font-size:.75rem; color:#9ca3af; line-height:1.5; }

/* Holdings bar */
.fu-holdings { margin:1.25rem 0 1.75rem; }
.fu-holdings-label { font-size:.75rem; color:#6b7280; margin-bottom:.5rem; font-weight:500; }
.fu-bar { display:flex; height:10px; border-radius:9999px; overflow:hidden; gap:2px; margin-bottom:.65rem; }
.fu-bar-seg { height:100%; border-radius:2px; }
.fu-bar-legend { display:flex; flex-wrap:wrap; gap:.6rem; }
.fu-leg { display:flex; align-items:center; gap:.3rem; font-size:.72rem; color:#9ca3af; }
.fu-leg-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

/* Council box */
.fu-council { background:rgba(255,215,0,.04); border:1px solid rgba(255,215,0,.15); border-radius:10px; padding:1rem 1.25rem; margin:1.5rem 0; display:flex; gap:1rem; align-items:flex-start; }
.fu-council-icon { font-size:1.4rem; flex-shrink:0; margin-top:.1rem; }
.fu-council-body { flex:1; }
.fu-council-outcome { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#fbbf24; margin-bottom:.35rem; }
